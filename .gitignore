# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example

# training fixtures (real client docs)
fixtures/training-docs/**
!fixtures/training-docs/README.md

# vercel
.vercel

# smoke test output
scripts/smoke-pipeline-output.json

# typescript
*.tsbuildinfo
next-env.d.ts
